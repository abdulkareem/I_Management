{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@prism/database": ["packages/database/src/index.ts"],
      "@prism/types": ["packages/types/src/index.ts"],
      "@prism/compliance": ["packages/compliance/src/index.ts"]
    }
  }
}
