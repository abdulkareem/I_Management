{
  "name": "internsuite-platform",
  "private": true,
  "version": "2.0.0",
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "npx prisma migrate deploy --schema=packages/db/prisma/schema.prisma && node server.js",
    "dev": "npm run dev --workspace @internsuite/web",
    "build": "npm run build --workspace @internsuite/types && npm run build --workspace @internsuite/utils && npm run build --workspace @internsuite/web",
    "typecheck": "npm run typecheck --workspace @internsuite/web",
    "lint": "npm run lint --workspace @internsuite/web",
    "db:migrate": "wrangler d1 execute internsuite-db --file ./packages/db/migrations/0001_init.sql --remote",
    "db:migrate:local": "wrangler d1 execute internsuite-db --file ./packages/db/migrations/0001_init.sql --local",
    "deploy:web": "npm run build --workspace @internsuite/web",
    "pages:build": "npm run build --workspace @internsuite/types && npm run build --workspace @internsuite/utils && npm run build --workspace @internsuite/web",
    "deploy:backend": "npm run deploy --workspace @internsuite/backend",
    "db:prisma:generate": "npx prisma generate --schema packages/db/prisma/schema.prisma",
    "db:prisma:push": "npx prisma db push --schema packages/db/prisma/schema.prisma",
    "db:prisma:studio": "npx prisma studio --schema packages/db/prisma/schema.prisma",
    "db:seed": "node packages/db/prisma/seed.js",
    "db:railway:migrate": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f ./packages/db/schema.sql",
    "db:railway:reset": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -c \"DROP SCHEMA IF EXISTS public CASCADE; CREATE SCHEMA public;\" && npm run db:railway:migrate",
    "db:railway:fresh": "npm run db:railway:reset && npm run db:prisma:push",
    "db:railway:update": "npm run db:railway:migrate",
    "db:prisma:sync": "node ./backend/scripts/prisma-auto-sync.mjs",
    "db:prisma:sync:force": "node ./backend/scripts/prisma-auto-sync.mjs --accept-data-loss",
    "db:force-deploy": "node ./backend/scripts/db-force-deploy.mjs"
  },
  "prisma": {
    "seed": "node packages/db/prisma/seed.js"
  }
}
