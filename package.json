{
  "name": "internsuite-platform",
  "private": true,
  "version": "2.0.0",
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npx prisma generate --schema=backend/prisma/schema.prisma && npm run build --workspaces --if-present",
    "prisma:generate": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema=backend/prisma/schema.prisma"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  }
}
