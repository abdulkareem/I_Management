generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  COLLEGE
  STUDENT
  INDUSTRY
  ADMIN
}

enum SubscriptionPlan {
  FOUNDATION
  GROWTH
}

enum IndustryField {
  IT
  MANUFACTURING
  HEALTHCARE
  FINANCE
  EDUCATION
  RETAIL
  LOGISTICS
  AGRICULTURE
  MEDIA
  GOVERNMENT
  OTHER
}

enum InternshipVisibility {
  PUBLIC
  SELECTED
  INTERNAL
}

enum ApplicationStatus {
  APPLIED
  APPROVED
  REJECTED
}

enum ApprovalStage {
  INTERNSHIP
  STUDENT_APPLICATION
  ATTENDANCE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum DocumentType {
  MOU
  APPROVAL_LETTER
  ATTENDANCE_REPORT
  MARKSHEET
}

enum FileStorageType {
  LOGO
  PHOTO
  PDF
  RESUME
}

enum OtpPurpose {
  REGISTRATION
  PASSWORD_RESET
  LOGIN_CHALLENGE
}

model Tenant {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       User[]
  colleges    College[]
  industries  Industry[]
  students    Student[]
  internships Internship[]
  applications Application[]
  mous        MOU[]
  attendance  Attendance[]
  evaluations Evaluation[]
  marksheets  Marksheet[]
  approvalLetters ApprovalLetter[]
  files       FileStorage[]
  otpChallenges OtpChallenge[]
  approvals   WorkflowApproval[]

  @@index([isActive])
}

model User {
  id            String      @id @default(cuid())
  tenantId      String
  email         String      @unique
  password      String?
  role          UserRole
  isVerified    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  college       College?
  industry      Industry?
  student       Student?
  otpChallenges OtpChallenge[]

  @@index([tenantId, role])
  @@index([tenantId, isVerified])
}

model College {
  id               String           @id @default(cuid())
  tenantId         String
  userId           String           @unique
  name             String
  logoUrl          String?
  address          String
  university       String
  isAutonomous     Boolean          @default(false)
  subscriptionPlan SubscriptionPlan @default(FOUNDATION)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  students         Student[]
  approvals        WorkflowApproval[]
  internships      Internship[]     @relation("ApprovedByCollege")
  applications     Application[]
  mous             MOU[]
  attendance       Attendance[]
  evaluations      Evaluation[]
  marksheets       Marksheet[]

  @@index([tenantId, isActive])
  @@index([tenantId, subscriptionPlan])
}

model Industry {
  id                String         @id @default(cuid())
  tenantId          String
  userId            String         @unique
  name              String
  logoUrl           String?
  industryField     IndustryField
  description       String?
  internshipRoles   String[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  internships       Internship[]
  applications      Application[]
  mous              MOU[]
  attendance        Attendance[]
  approvals         WorkflowApproval[] @relation("IndustryApprovals")

  @@index([tenantId, industryField])
}

model Student {
  id                String      @id @default(cuid())
  tenantId          String
  userId            String      @unique
  collegeId         String
  email             String
  fullName          String
  universityRegNo   String
  dob               DateTime
  whatsappNumber    String
  address           String
  programme         String
  year              Int
  semester          Int
  photoUrl          String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  college           College     @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  applications      Application[]
  attendance        Attendance[]
  evaluations       Evaluation[]
  marksheets        Marksheet[]

  @@unique([email, universityRegNo])
  @@unique([collegeId, universityRegNo])
  @@index([tenantId, collegeId])
  @@index([tenantId, semester])
}

model Internship {
  id                  String               @id @default(cuid())
  tenantId            String
  collegeId           String?
  title               String
  description         String
  field               IndustryField
  duration            String
  stipend             Decimal?             @db.Decimal(10, 2)
  createdByIndustryId String
  visibility          InternshipVisibility @default(PUBLIC)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  college             College?             @relation("ApprovedByCollege", fields: [collegeId], references: [id], onDelete: SetNull)
  industry            Industry             @relation(fields: [createdByIndustryId], references: [id], onDelete: Cascade)
  applications        Application[]
  approvals           WorkflowApproval[]

  @@index([tenantId, visibility])
  @@index([tenantId, createdByIndustryId])
  @@index([tenantId, collegeId])
}

model Application {
  id             String            @id @default(cuid())
  tenantId       String
  collegeId      String
  studentId      String
  internshipId   String
  industryId     String
  status         ApplicationStatus @default(APPLIED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  college        College           @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  student        Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internship     Internship        @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  industry       Industry          @relation(fields: [industryId], references: [id], onDelete: Cascade)
  approvalLetter ApprovalLetter?
  approvals      WorkflowApproval[]

  @@unique([studentId, internshipId])
  @@index([tenantId, collegeId, status])
  @@index([tenantId, industryId, status])
}

model MOU {
  id             String      @id @default(cuid())
  tenantId       String
  collegeId      String
  industryId     String
  fileUrl        String
  createdAt      DateTime    @default(now())
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  college        College     @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  industry       Industry    @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([collegeId, industryId])
  @@index([tenantId, createdAt])
}

model ApprovalLetter {
  id             String      @id @default(cuid())
  tenantId       String
  applicationId  String      @unique
  fileUrl        String
  createdAt      DateTime    @default(now())
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model Attendance {
  id                String           @id @default(cuid())
  tenantId          String
  collegeId         String
  studentId         String
  industryId        String
  applicationId     String?
  date              DateTime
  status            AttendanceStatus
  approvedByCollege Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  college           College          @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  industry          Industry         @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([tenantId, collegeId, date])
  @@index([tenantId, industryId, date])
}

model Evaluation {
  id             String      @id @default(cuid())
  tenantId       String
  collegeId      String
  studentId      String
  applicationId  String?
  marks          Decimal     @db.Decimal(5, 2)
  grade          String
  remarks        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  college        College     @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  student        Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId, collegeId, createdAt])
  @@index([tenantId, studentId])
}

model Marksheet {
  id             String      @id @default(cuid())
  tenantId       String
  collegeId      String
  studentId      String
  evaluationId   String?
  fileUrl        String
  createdAt      DateTime    @default(now())
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  college        College     @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  student        Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId, collegeId, createdAt])
  @@index([tenantId, studentId])
}

model FileStorage {
  id          String          @id @default(cuid())
  tenantId    String
  url         String
  type        FileStorageType
  size        Int
  ownerUserId String?
  createdAt   DateTime        @default(now())
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type])
  @@index([tenantId, createdAt])
}

model OtpChallenge {
  id          String     @id @default(cuid())
  tenantId    String
  userId      String
  email       String
  purpose     OtpPurpose
  otpHash     String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime   @default(now())
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, email, purpose])
  @@index([userId, expiresAt])
}

model WorkflowApproval {
  id            String         @id @default(cuid())
  tenantId      String
  collegeId     String
  industryId    String?
  internshipId  String?
  applicationId String?
  stage         ApprovalStage
  status        ApprovalStatus @default(PENDING)
  remarks       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  college       College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  industry      Industry?      @relation("IndustryApprovals", fields: [industryId], references: [id], onDelete: SetNull)
  internship    Internship?    @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  application   Application?   @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId, collegeId, stage, status])
  @@index([tenantId, industryId, stage])
}
