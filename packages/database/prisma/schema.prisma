generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  PRINCIPAL
  INTERNSHIP_COORDINATOR
  DEPARTMENT_COORDINATOR
  FACULTY_MENTOR
  STUDENT
  INDUSTRY_ADMIN
  INDUSTRY_SUPERVISOR
}

enum AuthScope {
  COLLEGE
  STUDENT
  INDUSTRY
  SUPER_ADMIN
}

enum InternshipType {
  MAJOR
  MINOR
  INTERDISCIPLINARY
  ALLIED
}

enum InternshipMode {
  OFFLINE
  ONLINE
}

enum ProviderCategory {
  EDUCATIONAL_INSTITUTION
  RESEARCH_LAB
  GOVERNMENT_INSTITUTION
  NGO
  MSME_OR_INDUSTRY
  BANK_OR_FINANCIAL
  IT_OR_DIGITAL
  HEALTHCARE_OR_WELLNESS
  MEDIA_OR_CULTURAL
  AGRICULTURE_OR_ENVIRONMENT
}

enum InternshipStatus {
  DRAFT
  SUBMITTED
  DEPARTMENT_REVIEW
  DEPARTMENT_APPROVED
  COLLEGE_APPROVED
  ACTIVE
  COMPLETED
  REJECTED
}

enum PaymentStatus {
  PENDING
  FACULTY_VERIFIED
  COORDINATOR_VERIFIED
  PAID
  FAILED
}

enum StudentLifecycleStatus {
  ACTIVE
  AT_RISK
  READY_TO_ARCHIVE
  ARCHIVED
}

enum CollegePlanTier {
  FOUNDATION
  GROWTH
  STATEWIDE
}

enum SemesterCycleStatus {
  PLANNING
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ListingVisibility {
  PUBLIC
  SELECTED_COLLEGES
}

model User {
  id                 String                  @id @default(cuid())
  email              String                  @unique
  name               String
  phone              String?
  role               UserRole
  authScope          AuthScope               @default(COLLEGE)
  emailVerifiedAt    DateTime?
  passwordHash       String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  memberships        UserCollegeMembership[]
  student            Student?
  sessions           Session[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  logApprovals       Logbook[]               @relation("LogbookApprover")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  audience     String
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@index([audience, revokedAt])
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model College {
  id                           String                       @id @default(cuid())
  name                         String
  code                         String                       @unique
  tenantKey                    String                       @unique
  emblemUrl                    String?
  domain                       String?
  planTier                     CollegePlanTier              @default(FOUNDATION)
  activeStudentCapPerSemester  Int                          @default(500)
  archiveAllowanceStudents     Int                          @default(2000)
  subscriptionPlan             String                       @default("Foundation")
  departments                  Department[]
  students                     Student[]
  memberships                  UserCollegeMembership[]
  internships                  Internship[]
  subscriptions                Subscription[]
  semesterCycles               SemesterCycle[]
  programRules                 ProgramRule[]
  applications                 Application[]
  payments                     Payment[]
  mous                         MoU[]
  reports                      Report[]
  sharedListings               InternshipListingCollege[]
  partnerColleges              PartnerCollegeLink[]         @relation("PartnerCollegeSource")
  partnerWithColleges          PartnerCollegeLink[]         @relation("PartnerCollegeTarget")
  archivedStudentSnapshots     ArchivedStudentSnapshot[]

  @@index([planTier])
}

model UserCollegeMembership {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  role      UserRole
  user      User     @relation(fields: [userId], references: [id])
  college   College  @relation(fields: [collegeId], references: [id])

  @@unique([userId, collegeId, role])
  @@index([collegeId, role])
}

model Department {
  id        String      @id @default(cuid())
  collegeId String
  name      String
  code      String
  college   College     @relation(fields: [collegeId], references: [id])
  students  Student[]

  @@unique([collegeId, code])
  @@index([collegeId, name])
}

model SemesterCycle {
  id             String              @id @default(cuid())
  collegeId      String
  label          String
  academicYear   String
  semesterNumber Int
  startsOn       DateTime
  endsOn         DateTime
  archiveOn      DateTime
  status         SemesterCycleStatus @default(PLANNING)
  college        College             @relation(fields: [collegeId], references: [id])
  students       Student[]
  internships    Internship[]
  applications   Application[]
  archivedStudentSnapshots ArchivedStudentSnapshot[]

  @@unique([collegeId, academicYear, semesterNumber])
  @@index([collegeId, status, semesterNumber])
}

model Student {
  id                  String                 @id @default(cuid())
  userId              String                 @unique
  collegeId           String
  departmentId        String
  semesterCycleId     String?
  registerNumber      String                 @unique
  semester            Int
  program             String
  lifecycleStatus     StudentLifecycleStatus @default(ACTIVE)
  archivedAt          DateTime?
  archiveCompressedAt DateTime?
  skillProfile        Json?
  user                User                   @relation(fields: [userId], references: [id])
  college             College                @relation(fields: [collegeId], references: [id])
  department          Department             @relation(fields: [departmentId], references: [id])
  semesterCycle       SemesterCycle?         @relation(fields: [semesterCycleId], references: [id])
  internships         Internship[]
  applications        Application[]
  reports             Report[]
  certificates        Certificate[]
  evaluations         Evaluation[]
  payments            Payment[]
  attendance          Attendance[]
  logbooks            Logbook[]
  archiveSnapshots    ArchivedStudentSnapshot[]

  @@index([collegeId, lifecycleStatus, semester])
  @@index([semesterCycleId, lifecycleStatus])
}

model ArchivedStudentSnapshot {
  id                String    @id @default(cuid())
  collegeId         String
  studentId         String
  semesterCycleId   String?
  registerNumber    String
  studentName       String
  departmentName    String
  program           String
  archivedAt        DateTime
  reportSummary     String?
  outcomeSummary    String?
  compressedDocRefs Json?
  college           College   @relation(fields: [collegeId], references: [id])
  student           Student   @relation(fields: [studentId], references: [id])
  semesterCycle     SemesterCycle? @relation(fields: [semesterCycleId], references: [id])

  @@index([collegeId, archivedAt])
  @@index([studentId])
}

model Industry {
  id                      String                  @id @default(cuid())
  name                    String
  isPrivate               Boolean                 @default(false)
  yearsOfExperience       Int                     @default(0)
  linkedPartnerExperience Int?
  providerCategory        ProviderCategory
  district                String?
  contactEmail            String?
  contactPhone            String?
  internships             Internship[]
  listings                InternshipListing[]
  mous                    MoU[]

  @@index([providerCategory])
}

model InternshipListing {
  id                  String                     @id @default(cuid())
  industryId          String
  title               String
  description         String
  visibility          ListingVisibility         @default(PUBLIC)
  seats               Int
  mode                InternshipMode
  internshipType      InternshipType
  semesterPreference  Int?
  applicationDeadline DateTime
  isPublished         Boolean                   @default(false)
  createdAt           DateTime                  @default(now())
  industry            Industry                  @relation(fields: [industryId], references: [id])
  colleges            InternshipListingCollege[]
  applications        Application[]

  @@index([industryId, isPublished])
  @@index([visibility, applicationDeadline])
}

model InternshipListingCollege {
  id          String            @id @default(cuid())
  listingId   String
  collegeId   String
  isPreferred Boolean           @default(false)
  listing     InternshipListing @relation(fields: [listingId], references: [id])
  college     College           @relation(fields: [collegeId], references: [id])

  @@unique([listingId, collegeId])
  @@index([collegeId, isPreferred])
}

model PartnerCollegeLink {
  id              String    @id @default(cuid())
  sourceCollegeId String
  targetCollegeId String
  status          String    @default("ACTIVE")
  notes           String?
  createdAt       DateTime  @default(now())
  sourceCollege   College   @relation("PartnerCollegeSource", fields: [sourceCollegeId], references: [id])
  targetCollege   College   @relation("PartnerCollegeTarget", fields: [targetCollegeId], references: [id])

  @@unique([sourceCollegeId, targetCollegeId])
  @@index([sourceCollegeId, status])
  @@index([targetCollegeId, status])
}

model Internship {
  id                        String           @id @default(cuid())
  collegeId                 String
  studentId                 String
  industryId                String
  semesterCycleId           String?
  listingId                 String?
  title                     String
  internshipType            InternshipType
  mode                      InternshipMode
  status                    InternshipStatus @default(DRAFT)
  externalPlatform          String?
  startDate                 DateTime
  endDate                   DateTime
  totalHours                Int
  departmentCouncilApproved Boolean          @default(false)
  industrySupervisorName    String
  ownCollegeRestricted      Boolean          @default(true)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  college                   College          @relation(fields: [collegeId], references: [id])
  student                   Student          @relation(fields: [studentId], references: [id])
  industry                  Industry         @relation(fields: [industryId], references: [id])
  semesterCycle             SemesterCycle?   @relation(fields: [semesterCycleId], references: [id])
  listing                   InternshipListing? @relation(fields: [listingId], references: [id])
  applications              Application[]
  attendance                Attendance[]
  logbooks                  Logbook[]
  report                    Report?
  certificate               Certificate?
  evaluation                Evaluation?
  payment                   Payment?

  @@index([collegeId, semesterCycleId, status])
  @@index([studentId, status])
  @@index([industryId, status])
}

model Application {
  id            String           @id @default(cuid())
  collegeId     String
  studentId     String
  internshipId  String
  semesterCycleId String?
  listingId     String?
  preference    Int
  rankScore     Float
  workflowState InternshipStatus @default(SUBMITTED)
  createdAt     DateTime         @default(now())
  college       College          @relation(fields: [collegeId], references: [id])
  student       Student          @relation(fields: [studentId], references: [id])
  internship    Internship       @relation(fields: [internshipId], references: [id])
  semesterCycle SemesterCycle?   @relation(fields: [semesterCycleId], references: [id])
  listing       InternshipListing? @relation(fields: [listingId], references: [id])

  @@unique([studentId, internshipId])
  @@index([collegeId, workflowState])
  @@index([semesterCycleId, workflowState])
}

model Attendance {
  id            String     @id @default(cuid())
  studentId     String
  internshipId  String
  date          DateTime
  present       Boolean
  remarks       String?
  supervisorSig String?
  student       Student    @relation(fields: [studentId], references: [id])
  internship    Internship @relation(fields: [internshipId], references: [id])

  @@unique([studentId, internshipId, date])
  @@index([internshipId, date])
}

model Logbook {
  id               String     @id @default(cuid())
  studentId        String
  internshipId     String
  workDate         DateTime
  taskSummary      String
  outcomes         String?
  approvedAt       DateTime?
  approverUserId   String?
  supervisorRemark String?
  student          Student    @relation(fields: [studentId], references: [id])
  internship       Internship @relation(fields: [internshipId], references: [id])
  approver         User?      @relation("LogbookApprover", fields: [approverUserId], references: [id])

  @@index([internshipId, workDate])
}

model Report {
  id                String     @id @default(cuid())
  collegeId         String
  studentId         String
  internshipId      String     @unique
  title             String
  language          String     @default("English")
  durationSummary   String
  workDone          String
  outcomes          String
  supervisorSignUrl String?
  submittedAt       DateTime?
  college           College    @relation(fields: [collegeId], references: [id])
  student           Student    @relation(fields: [studentId], references: [id])
  internship        Internship @relation(fields: [internshipId], references: [id])

  @@index([collegeId, submittedAt])
}

model Certificate {
  id             String     @id @default(cuid())
  studentId      String
  internshipId   String     @unique
  certificateUrl String
  issuedAt       DateTime?
  student        Student    @relation(fields: [studentId], references: [id])
  internship     Internship @relation(fields: [internshipId], references: [id])

  @@index([studentId, issuedAt])
}

model Evaluation {
  id            String     @id @default(cuid())
  studentId     String
  internshipId  String     @unique
  ccaMarks      Int
  eseMarks      Int
  totalMarks    Int
  evaluatedAt   DateTime?
  student       Student    @relation(fields: [studentId], references: [id])
  internship    Internship @relation(fields: [internshipId], references: [id])

  @@index([studentId, evaluatedAt])
}

model Payment {
  id                    String        @id @default(cuid())
  collegeId             String
  studentId             String
  internshipId          String?       @unique
  amountInInr           Int
  source                String
  status                PaymentStatus @default(PENDING)
  facultyVerifiedAt     DateTime?
  coordinatorVerifiedAt DateTime?
  transactionRef        String?
  college               College       @relation(fields: [collegeId], references: [id])
  student               Student       @relation(fields: [studentId], references: [id])
  internship            Internship?   @relation(fields: [internshipId], references: [id])

  @@index([collegeId, status])
}

model Subscription {
  id              String          @id @default(cuid())
  collegeId       String
  tier            CollegePlanTier @default(FOUNDATION)
  annualPriceInInr Int            @default(22000)
  activeFrom      DateTime
  activeTo        DateTime?
  college         College         @relation(fields: [collegeId], references: [id])

  @@index([collegeId, tier])
}

model ProgramRule {
  id            String   @id @default(cuid())
  collegeId     String?
  programName   String
  minimumHours  Int
  submissionDue String
  college       College? @relation(fields: [collegeId], references: [id])

  @@index([collegeId, programName])
}

model SystemRule {
  id          String   @id @default(cuid())
  ruleKey     String   @unique
  ruleValue   Json
  description String?
  updatedAt   DateTime @updatedAt
}

model MoU {
  id          String    @id @default(cuid())
  collegeId   String
  industryId  String
  documentUrl String
  signedAt    DateTime?
  expiresAt   DateTime?
  college     College   @relation(fields: [collegeId], references: [id])
  industry    Industry  @relation(fields: [industryId], references: [id])

  @@unique([collegeId, industryId])
  @@index([collegeId, expiresAt])
}
