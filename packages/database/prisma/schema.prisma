generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserRole {
  SUPER_ADMIN
  COLLEGE_ADMIN
  COLLEGE_STAFF
  STUDENT
  INDUSTRY_ADMIN
  INDUSTRY_SUPERVISOR
}

enum IdentityStatus {
  PENDING_VERIFICATION
  VERIFIED
  PASSWORD_SET
  SUSPENDED
}

enum ChallengePurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  PASSWORD_SET
}

enum ChallengeChannel {
  EMAIL_LINK
  EMAIL_OTP
}

enum FileKind {
  COLLEGE_LOGO
  INDUSTRY_LOGO
  STUDENT_PASSPORT_PHOTO
  STUDENT_RESUME
  GENERATED_PDF
  SUPPORTING_ATTACHMENT
}

enum FileVisibility {
  PRIVATE
  TENANT
  SHARED
}

enum InternshipType {
  MAJOR
  MINOR
  INTERDISCIPLINARY
  ALLIED
}

enum InternshipMode {
  OFFLINE
  ONLINE
  HYBRID
}

enum ProviderCategory {
  EDUCATIONAL_INSTITUTION
  RESEARCH_LAB
  GOVERNMENT_INSTITUTION
  NGO
  MSME_OR_INDUSTRY
  BANK_OR_FINANCIAL
  IT_OR_DIGITAL
  HEALTHCARE_OR_WELLNESS
  MEDIA_OR_CULTURAL
  AGRICULTURE_OR_ENVIRONMENT
}

enum InternshipStatus {
  DRAFT
  PENDING_COLLEGE_APPROVAL
  APPROVED
  REJECTED
  OPEN_FOR_APPLICATIONS
  PLACEMENT_IN_PROGRESS
  ACTIVE
  COMPLETED
  CLOSED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  SUBMITTED
  COLLEGE_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
  SELECTED
}

enum AttendancePeriod {
  DAILY
  WEEKLY
}

enum AttendanceReviewStatus {
  DRAFT
  SUBMITTED_TO_COLLEGE
  APPROVED_BY_COLLEGE
  REJECTED_BY_COLLEGE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
}

enum DocumentType {
  MOU
  APPROVAL_LETTER
  ATTENDANCE_REPORT
  MARKSHEET
}

enum DocumentStatus {
  DRAFT
  GENERATED
  SHARED
  SIGNED
  ARCHIVED
}

enum EvaluationStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum MarksheetStatus {
  DRAFT
  PUBLISHED
}

model Tenant {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  status      TenantStatus    @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  users       User[]
  colleges    College[]
  industries  Industry[]
  students    Student[]
  internships Internship[]
  applications Application[]
  files       FileStorage[]
  documents   GeneratedDocument[]
  mous        Mou[]
  attendanceBatches AttendanceBatch[]
  evaluations Evaluation[]
  marksheets  Marksheet[]

  @@index([status])
}

model User {
  id                 String              @id @default(cuid())
  tenantId           String
  email              String              @unique
  name               String
  phone              String?
  role               UserRole
  identityStatus     IdentityStatus      @default(PENDING_VERIFICATION)
  passwordHash       String?
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  college            College?
  industry           Industry?
  student            Student?
  sessions           Session[]
  challenges         IdentityChallenge[]
  uploadedFiles      FileStorage[]       @relation("FileUploader")
  approvedInternships CollegeApproval[]  @relation("ApprovalActor")
  reviewedApplications Application[]     @relation("ApplicationReviewer")
  attendanceBatches  AttendanceBatch[]   @relation("AttendanceSubmitter")
  attendanceRecords  AttendanceRecord[]  @relation("AttendanceMarker")
  evaluations        Evaluation[]        @relation("EvaluationAuthor")

  @@index([tenantId, role])
  @@index([tenantId, identityStatus])
}

model Session {
  id          String   @id @default(cuid())
  userId       String
  jwtId        String   @unique
  audience     String
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@index([audience, revokedAt])
}

model IdentityChallenge {
  id          String            @id @default(cuid())
  userId       String
  purpose      ChallengePurpose
  channel      ChallengeChannel
  tokenHash    String            @unique
  otpHash      String?
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime          @default(now())
  metadata     Json?
  user         User              @relation(fields: [userId], references: [id])

  @@index([userId, purpose, expiresAt])
}

model College {
  id              String             @id @default(cuid())
  tenantId        String
  primaryUserId   String             @unique
  code            String             @unique
  name            String
  logoFileId      String?
  domain          String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  primaryUser     User               @relation(fields: [primaryUserId], references: [id])
  logoFile        FileStorage?       @relation("CollegeLogo", fields: [logoFileId], references: [id])
  students        Student[]
  internships     Internship[]
  applications    Application[]
  targetListings  InternshipTargetCollege[]
  approvals       CollegeApproval[]
  attendanceBatches AttendanceBatch[]
  evaluations     Evaluation[]
  marksheets      Marksheet[]
  documents       GeneratedDocument[]

  @@index([tenantId, name])
}

model Industry {
  id                String             @id @default(cuid())
  tenantId          String
  primaryUserId     String             @unique
  name              String
  companyName       String
  logoFileId        String?
  providerCategory  ProviderCategory
  contactEmail      String             @unique
  contactPhone      String?
  yearsOfExperience Int                @default(0)
  isPrivate         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  primaryUser       User               @relation(fields: [primaryUserId], references: [id])
  logoFile          FileStorage?       @relation("IndustryLogo", fields: [logoFileId], references: [id])
  internships       Internship[]
  approvals         CollegeApproval[]
  attendanceBatches AttendanceBatch[]
  documents         GeneratedDocument[]

  @@index([tenantId, providerCategory])
}

model Student {
  id                           String              @id @default(cuid())
  tenantId                     String
  userId                       String              @unique
  collegeId                    String
  email                        String
  fullName                     String
  collegeStudentId             String
  universityRegistrationNumber String
  departmentName               String
  program                      String
  semester                     Int
  passportPhotoFileId          String?
  resumeFileId                 String?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  tenant                       Tenant              @relation(fields: [tenantId], references: [id])
  user                         User                @relation(fields: [userId], references: [id])
  college                      College             @relation(fields: [collegeId], references: [id])
  passportPhotoFile            FileStorage?        @relation("StudentPassportPhoto", fields: [passportPhotoFileId], references: [id])
  resumeFile                   FileStorage?        @relation("StudentResume", fields: [resumeFileId], references: [id])
  applications                 Application[]
  attendanceRecords            AttendanceRecord[]
  evaluations                  Evaluation[]
  marksheets                   Marksheet[]
  documents                    GeneratedDocument[]

  @@unique([email, universityRegistrationNumber])
  @@unique([collegeId, collegeStudentId])
  @@index([tenantId, collegeId, semester])
}

model Internship {
  id                  String             @id @default(cuid())
  tenantId            String
  collegeId           String
  industryId          String
  title               String
  description         String
  terms               Json
  seats               Int
  internshipType      InternshipType
  mode                InternshipMode
  providerCategory    ProviderCategory
  status              InternshipStatus   @default(DRAFT)
  applicationDeadline DateTime
  startsOn            DateTime
  endsOn              DateTime
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  college             College            @relation(fields: [collegeId], references: [id])
  industry            Industry           @relation(fields: [industryId], references: [id])
  targetColleges      InternshipTargetCollege[]
  approvals           CollegeApproval[]
  applications        Application[]
  attendanceBatches   AttendanceBatch[]
  attendanceRecords   AttendanceRecord[]
  evaluations         Evaluation[]
  marksheets          Marksheet[]
  documents           GeneratedDocument[]

  @@index([tenantId, status, applicationDeadline])
  @@index([collegeId, status])
  @@index([industryId, status])
}

model InternshipTargetCollege {
  id           String      @id @default(cuid())
  internshipId String
  collegeId    String
  createdAt    DateTime    @default(now())
  ruleset      Json?
  internship   Internship  @relation(fields: [internshipId], references: [id])
  college      College     @relation(fields: [collegeId], references: [id])

  @@unique([internshipId, collegeId])
  @@index([collegeId])
}

model CollegeApproval {
  id               String         @id @default(cuid())
  internshipId     String
  collegeId        String
  industryId       String
  approvedByUserId String?
  status           ApprovalStatus @default(PENDING)
  reviewedAt       DateTime?
  notes            String?
  internship       Internship     @relation(fields: [internshipId], references: [id])
  college          College        @relation(fields: [collegeId], references: [id])
  industry         Industry       @relation(fields: [industryId], references: [id])
  approvedBy       User?          @relation("ApprovalActor", fields: [approvedByUserId], references: [id])
  mou              Mou?

  @@unique([internshipId, collegeId])
  @@index([collegeId, status])
}

model Application {
  id                 String            @id @default(cuid())
  tenantId           String
  collegeId          String
  internshipId       String
  studentId          String
  reviewedByUserId   String?
  status             ApplicationStatus @default(SUBMITTED)
  coverLetter        String?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  college            College           @relation(fields: [collegeId], references: [id])
  internship         Internship        @relation(fields: [internshipId], references: [id])
  student            Student           @relation(fields: [studentId], references: [id])
  reviewedBy         User?             @relation("ApplicationReviewer", fields: [reviewedByUserId], references: [id])
  documents          GeneratedDocument[]

  @@unique([internshipId, studentId])
  @@index([tenantId, status])
  @@index([collegeId, status])
}

model Mou {
  id                String          @id @default(cuid())
  tenantId          String
  collegeApprovalId String          @unique
  documentId        String          @unique
  status            DocumentStatus  @default(GENERATED)
  signedAt          DateTime?
  expiresAt         DateTime?
  createdAt         DateTime        @default(now())
  document          GeneratedDocument @relation(fields: [documentId], references: [id])
  collegeApproval   CollegeApproval @relation(fields: [collegeApprovalId], references: [id])
  tenant            Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model AttendanceBatch {
  id                String                 @id @default(cuid())
  tenantId          String
  collegeId         String
  industryId        String
  internshipId      String
  submittedByUserId String
  period            AttendancePeriod
  reviewStatus      AttendanceReviewStatus @default(DRAFT)
  windowStartsOn    DateTime
  windowEndsOn      DateTime
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  tenant            Tenant                 @relation(fields: [tenantId], references: [id])
  college           College                @relation(fields: [collegeId], references: [id])
  industry          Industry               @relation(fields: [industryId], references: [id])
  internship        Internship             @relation(fields: [internshipId], references: [id])
  submittedBy       User                   @relation("AttendanceSubmitter", fields: [submittedByUserId], references: [id])
  records           AttendanceRecord[]
  documents         GeneratedDocument[]

  @@index([tenantId, reviewStatus])
  @@index([collegeId, internshipId])
}

model AttendanceRecord {
  id             String           @id @default(cuid())
  batchId         String
  studentId       String
  internshipId    String
  attendanceDate  DateTime
  status          AttendanceStatus
  markedByUserId  String
  remarks         String?
  createdAt       DateTime         @default(now())
  batch           AttendanceBatch  @relation(fields: [batchId], references: [id])
  student         Student          @relation(fields: [studentId], references: [id])
  internship      Internship       @relation(fields: [internshipId], references: [id])
  markedBy        User             @relation("AttendanceMarker", fields: [markedByUserId], references: [id])

  @@unique([studentId, internshipId, attendanceDate])
  @@index([batchId, attendanceDate])
}

model Evaluation {
  id               String           @id @default(cuid())
  tenantId         String
  collegeId        String
  internshipId     String
  studentId        String
  evaluatorUserId  String
  rubricSnapshot   Json
  internalMarks    Int
  externalMarks    Int
  totalMarks       Int
  status           EvaluationStatus @default(DRAFT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  college          College          @relation(fields: [collegeId], references: [id])
  internship       Internship       @relation(fields: [internshipId], references: [id])
  student          Student          @relation(fields: [studentId], references: [id])
  evaluator        User             @relation("EvaluationAuthor", fields: [evaluatorUserId], references: [id])
  marksheet        Marksheet?

  @@unique([internshipId, studentId])
  @@index([tenantId, status])
}

model Marksheet {
  id             String           @id @default(cuid())
  tenantId       String
  collegeId      String
  internshipId   String
  studentId      String
  evaluationId   String           @unique
  documentId     String           @unique
  totalMarks     Int
  letterGrade    String
  status         MarksheetStatus  @default(DRAFT)
  publishedAt    DateTime?
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  college        College          @relation(fields: [collegeId], references: [id])
  internship     Internship       @relation(fields: [internshipId], references: [id])
  student        Student          @relation(fields: [studentId], references: [id])
  evaluation     Evaluation       @relation(fields: [evaluationId], references: [id])
  document       GeneratedDocument @relation(fields: [documentId], references: [id])

  @@unique([internshipId, studentId])
  @@index([tenantId, status])
}

model FileStorage {
  id               String          @id @default(cuid())
  tenantId         String
  uploadedByUserId String?
  bucket           String
  objectKey        String          @unique
  fileName         String
  mimeType         String
  sizeBytes        Int
  checksumSha256   String?
  publicUrl        String?
  kind             FileKind
  visibility       FileVisibility  @default(PRIVATE)
  createdAt        DateTime        @default(now())
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  uploadedBy       User?           @relation("FileUploader", fields: [uploadedByUserId], references: [id])
  collegeLogoFor   College[]       @relation("CollegeLogo")
  industryLogoFor  Industry[]      @relation("IndustryLogo")
  passportPhotoFor Student[]       @relation("StudentPassportPhoto")
  resumeFor        Student[]       @relation("StudentResume")
  documents        GeneratedDocument[]

  @@index([tenantId, kind])
  @@index([tenantId, visibility])
}

model GeneratedDocument {
  id                String          @id @default(cuid())
  tenantId          String
  collegeId         String?
  industryId        String?
  studentId         String?
  internshipId      String?
  applicationId     String?
  attendanceBatchId String?
  fileId            String          @unique
  type              DocumentType
  status            DocumentStatus  @default(DRAFT)
  title             String
  templateVersion   String
  metadata          Json
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  college           College?        @relation(fields: [collegeId], references: [id])
  industry          Industry?       @relation(fields: [industryId], references: [id])
  student           Student?        @relation(fields: [studentId], references: [id])
  internship        Internship?     @relation(fields: [internshipId], references: [id])
  application       Application?    @relation(fields: [applicationId], references: [id])
  attendanceBatch   AttendanceBatch? @relation(fields: [attendanceBatchId], references: [id])
  file              FileStorage     @relation(fields: [fileId], references: [id])
  mou               Mou?
  marksheet         Marksheet?

  @@index([tenantId, type, status])
  @@index([collegeId, type])
  @@index([industryId, type])
  @@index([studentId, type])
}
