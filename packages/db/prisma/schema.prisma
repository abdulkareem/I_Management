generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COLLEGE
  DEPARTMENT
  INDUSTRY
  STUDENT
}

enum InternshipStatus {
  DRAFT
  SENT
  PUBLISHED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  REJECTED
  SELECTED
}

model College {
  id          String       @id @default(cuid())
  name        String
  departments Department[]
  students    Student[]
  internships Internship[]

  @@map("colleges")
}

model Department {
  id          String       @id @default(cuid())
  name        String
  collegeId   String       @map("college_id")
  college     College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  students    Student[]
  internships Internship[]

  @@map("departments")
}

model Industry {
  id          String       @id @default(cuid())
  name        String
  internships Internship[]

  @@map("industries")
}

model Student {
  id           String        @id @default(cuid())
  departmentId String        @map("department_id")
  collegeId    String        @map("college_id")
  department   Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  college      College       @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("students")
}

model Internship {
  id               String           @id @default(cuid())
  title            String
  description      String
  type             String
  departmentId     String           @map("department_id")
  collegeId        String           @map("college_id")
  industryId       String?          @map("industry_id")
  status           InternshipStatus @default(DRAFT)
  vacancy          Int
  gender           String           @default("BOTH")
  internshipType   String           @map("internship_type")
  feeAmount        Float?           @map("fee_amount")
  stipendAmount    Float?           @map("stipend_amount")
  stipendFrequency String?          @map("stipend_frequency")
  durationHours    Int?             @map("duration_hours")
  department       Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  college          College          @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  industry         Industry?        @relation(fields: [industryId], references: [id], onDelete: SetNull)
  applications     Application[]

  @@map("internships")
}

model Application {
  id           String            @id @default(cuid())
  studentId    String            @map("student_id")
  internshipId String            @map("internship_id")
  status       ApplicationStatus @default(APPLIED)
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internship   Internship        @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@unique([studentId, internshipId])
  @@map("applications")
}
