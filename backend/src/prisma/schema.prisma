generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COLLEGE_ADMIN
  DEPARTMENT_COORDINATOR
  INDUSTRY
  STUDENT
  EXTERNAL_STUDENT

  ADMIN
  COLLEGE
  COORDINATOR
}

enum CollegeStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  createdCollege     College?       @relation("CollegeCreator")
  coordinator        Coordinator?
  student            Student?
  industry           Industry?
  coordinatedDept    Department?    @relation("DepartmentCoordinator")

  @@index([role])
}

model College {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  address      String?
  university   String?
  status       CollegeStatus @default(PENDING_APPROVAL)
  emblemUrl    String?
  emblemBinary Bytes?
  createdById  String        @unique
  createdAt    DateTime      @default(now())

  createdBy   User           @relation("CollegeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  departments Department[]
  students    Student[]
  internships Internship[]

  @@index([name])
  @@index([status])
}

model Department {
  id                String   @id @default(cuid())
  name              String
  collegeId         String
  coordinatorId     String?  @unique
  coordinatorUserId String?  @unique
  createdAt         DateTime @default(now())

  college           College            @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  coordinator       Coordinator?       @relation(fields: [coordinatorId], references: [id])
  coordinatorUser   User?              @relation("DepartmentCoordinator", fields: [coordinatorUserId], references: [id])
  students          Student[]
  internshipIdeas   InternshipIdea[]
  interests         IndustryInterest[]
  internships       Internship[]

  @@unique([collegeId, name])
  @@index([collegeId])
}

model Coordinator {
  id           String   @id @default(cuid())
  userId       String   @unique
  departmentId String?  @unique
  phone        String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department?
  createdIdeas InternshipIdea[]

  @@index([departmentId])
}

model Student {
  id           String   @id @default(cuid())
  userId       String   @unique
  collegeId    String
  departmentId String
  createdAt    DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  college      College       @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  department   Department    @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  applications Application[]
  attendance   Attendance[]

  @@index([collegeId])
  @@index([departmentId])
}

model Industry {
  id                  String   @id @default(cuid())
  name                String
  registrationDetails String?
  emblemUrl           String?
  emblemBinary        Bytes?
  userId              String   @unique
  email               String?
  approved            Boolean  @default(false)
  createdAt           DateTime @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests   IndustryInterest[]
  internships Internship[]

  @@index([name])
}

model InternshipIdea {
  id           String   @id @default(cuid())
  title        String
  description  String
  outcomes     String
  departmentId String
  createdById  String
  createdAt    DateTime @default(now())

  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdBy    Coordinator @relation(fields: [createdById], references: [id], onDelete: Cascade)
  internships  Internship[]

  @@index([departmentId])
  @@index([createdById])
}

model IndustryInterest {
  id           String   @id @default(cuid())
  industryId   String
  departmentId String
  createdAt    DateTime @default(now())

  industry     Industry   @relation(fields: [industryId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([industryId, departmentId])
  @@index([departmentId])
}

model Internship {
  id           String   @id @default(cuid())
  title        String   @default("")
  description  String   @default("")
  industryId   String
  collegeId    String
  departmentId String
  ideaId       String
  createdAt    DateTime @default(now())

  industry     Industry       @relation(fields: [industryId], references: [id], onDelete: Cascade)
  college      College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  department   Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  idea         InternshipIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  applications Application[]
  attendance   Attendance[]

  @@index([industryId])
  @@index([collegeId])
  @@index([departmentId])
}

model Application {
  id           String            @id @default(cuid())
  studentId    String?
  studentName  String?
  email        String?
  phone        String?
  internshipId String
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())

  student      Student?   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@unique([studentId, internshipId])
  @@index([internshipId, status])
}

model Attendance {
  id           String           @id @default(cuid())
  studentId    String
  internshipId String
  date         DateTime
  status       AttendanceStatus
  createdAt    DateTime         @default(now())

  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@unique([studentId, internshipId, date])
  @@index([internshipId, date])
}
