{
  "name": "internsuite-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "prisma generate && tsc && node --test dist/test/**/*.test.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:validate": "prisma validate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.1",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "nodemon": "^3.1.10",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2"
  }
}
