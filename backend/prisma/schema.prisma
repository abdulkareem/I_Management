generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  colleges         College[]
  industries       Industry[]
  students         Student[]
  externalStudents ExternalStudent[]
}

enum Role {
  SUPER_ADMIN
  COLLEGE_ADMIN
  INDUSTRY
  STUDENT
  EXTERNAL_STUDENT
}

model College {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  address       String
  university    String
  status        String
  coordinatorId String

  coordinator User         @relation(fields: [coordinatorId], references: [id])
  internships Internship[]
  students    Student[]
}

model Industry {
  id       String  @id @default(cuid())
  name     String
  email    String
  typeId   String
  approved Boolean @default(false)

  userId String
  user   User @relation(fields: [userId], references: [id])

  type IndustryType @relation(fields: [typeId], references: [id])
}

model IndustryType {
  id   String @id @default(cuid())
  name String

  industries Industry[]
}

model Internship {
  id          String @id @default(cuid())
  title       String
  description String
  collegeId   String

  college      College       @relation(fields: [collegeId], references: [id])
  applications Application[]
}

model Student {
  id        String @id @default(cuid())
  name      String
  email     String @unique
  phone     String
  collegeId String

  userId String
  user   User @relation(fields: [userId], references: [id])

  college      College       @relation(fields: [collegeId], references: [id])
  applications Application[]
}

model ExternalStudent {
  id         String @id @default(cuid())
  name       String
  email      String @unique
  phone      String
  college    String
  university String

  userId String
  user   User @relation(fields: [userId], references: [id])
}

model Application {
  id           String @id @default(cuid())
  studentId    String
  internshipId String

  student    Student    @relation(fields: [studentId], references: [id])
  internship Internship @relation(fields: [internshipId], references: [id])
}
