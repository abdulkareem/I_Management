generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COLLEGE_COORDINATOR
  INDUSTRY
  STUDENT
}

enum MouStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ApplicationStatus {
  APPLIED
  ACCEPTED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())

  college  College?
  industry Industry?
  student  Student?

  @@index([role])
  @@index([createdAt])
}

model College {
  id            String   @id @default(cuid())
  name          String
  emblem        String?
  address       String
  coordinatorId String   @unique
  coordinator   User     @relation(fields: [coordinatorId], references: [id], onDelete: Cascade)

  departments Department[]
  students    Student[]
  mous        MoU[]

  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
}

model Industry {
  id          String   @id @default(cuid())
  name        String
  emblem      String?
  description String?
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunities InternshipOpportunity[]
  mous          MoU[]
  attendances   Attendance[]

  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
}

model Department {
  id        String  @id @default(cuid())
  name      String
  collegeId String
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  students Student[]

  @@unique([collegeId, name])
  @@index([collegeId])
}

model Student {
  id              String    @id @default(cuid())
  userId          String    @unique
  collegeId       String
  departmentId    String?
  universityRegNo String    @unique
  dob             DateTime
  whatsapp        String
  address         String

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  college    College     @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])

  applications Application[]
  attendances  Attendance[]

  createdAt DateTime @default(now())

  @@index([collegeId])
  @@index([departmentId])
  @@index([createdAt])
}

model MoU {
  id         String    @id @default(cuid())
  collegeId  String
  industryId String
  status     MouStatus @default(PENDING)
  signedAt   DateTime?
  pdfUrl     String?

  college  College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  industry Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([collegeId, industryId])
  @@index([collegeId, status])
  @@index([industryId, status])
}

model InternshipOpportunity {
  id          String   @id @default(cuid())
  industryId  String
  title       String
  description String

  industry     Industry      @relation(fields: [industryId], references: [id], onDelete: Cascade)
  applications Application[]

  createdAt DateTime @default(now())

  @@index([industryId])
  @@index([createdAt])
}

model Application {
  id            String            @id @default(cuid())
  studentId     String
  opportunityId String
  status        ApplicationStatus @default(APPLIED)
  acceptanceUrl String?

  student     Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  opportunity InternshipOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([studentId, opportunityId])
  @@index([opportunityId, status])
  @@index([studentId, status])
}

model Attendance {
  id         String           @id @default(cuid())
  studentId  String
  industryId String
  date       DateTime
  status     AttendanceStatus

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  industry Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([industryId, date])
}
