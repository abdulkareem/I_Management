generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  COLLEGE_COORDINATOR
  DEPARTMENT_COORDINATOR
  IPO
  STUDENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  phone     String?  @unique
  password  String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profiles
  studentProfile Student?
  ipoProfile     Ipo?

  // Relations
  internshipsCreated Internship[]          @relation("CreatedInternships")
  selectionsMade     Selection[]           @relation("SelectionByUser")
  results            Result[]              @relation("StudentResults")
  applications       InternshipApplication[] @relation("UserApplications")
  adminOtps          AdminOtp[]
}

model AdminOtp {
  id        String   @id @default(uuid())
  userId    String
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  verifiedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model College {
  id               String         @id @default(uuid())
  name             String
  address          String?
  university       String?
  mobile           String?
  coordinatorName  String?
  coordinatorEmail String?
  status           ApprovalStatus @default(PENDING)

  createdAt DateTime @default(now())

  departments       Department[]
  students          Student[]
  internshipTargets InternshipTarget[]
  results           Result[]
}

model Department {
  id        String @id @default(uuid())
  name      String
  collegeId String

  college  College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  students Student[]
}

model Student {
  id                    String @id @default(uuid())
  userId                String @unique
  collegeId             String?
  departmentId          String?

  // 🔥 NEW FIELDS
  universityRegNumber   String?
  sex                   String?
  collegeNameManual     String?
  departmentNameManual  String?
  programme             String?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  college    College?   @relation(fields: [collegeId], references: [id], onDelete: SetNull)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  applications InternshipApplication[] @relation("StudentApplications")
}

model Ipo {
  id              String @id @default(uuid())

  // 🔥 UPDATED
  name            String   // IPO Name
  email           String?
  activity        String?
  ipoType         String?
  ipoSubCategory  String?

  userId          String   @unique

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  internships  Internship[]
}

model Internship {
  id          String   @id @default(uuid())
  title       String
  description String?
  ipoId       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ipo       Ipo?  @relation(fields: [ipoId], references: [id], onDelete: SetNull)
  createdBy User? @relation("CreatedInternships", fields: [createdById], references: [id], onDelete: SetNull)

  applications InternshipApplication[]
  targets      InternshipTarget[]
}

model InternshipTarget {
  id           String @id @default(uuid())
  internshipId String
  collegeId    String?

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  college    College?   @relation(fields: [collegeId], references: [id], onDelete: SetNull)
}

model InternshipApplication {
  id           String   @id @default(uuid())
  internshipId String
  studentId    String?
  userId       String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  student Student? @relation("StudentApplications", fields: [studentId], references: [id], onDelete: Cascade)
  user    User?    @relation("UserApplications", fields: [userId], references: [id], onDelete: SetNull)

  selections Selection[]
  results    Result[]
}

model Selection {
  id            String   @id @default(uuid())
  applicationId String
  selectedById  String?
  createdAt     DateTime @default(now())

  application InternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  selectedBy  User?                 @relation("SelectionByUser", fields: [selectedById], references: [id], onDelete: SetNull)
}

model Result {
  id            String   @id @default(uuid())
  applicationId String
  studentId     String
  collegeId     String?
  resultStatus  String
  createdAt     DateTime @default(now())

  application InternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  student     User                  @relation("StudentResults", fields: [studentId], references: [id], onDelete: Cascade)
  college     College?              @relation(fields: [collegeId], references: [id], onDelete: SetNull)
}
