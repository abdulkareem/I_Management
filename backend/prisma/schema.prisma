generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  COLLEGE_COORDINATOR
  DEPARTMENT_COORDINATOR
  IPO
  STUDENT
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  phone     String?  @unique
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🔁 Relations
  internshipsCreated Internship[]          @relation("CreatedInternships")
  selectionsMade     Selection[]           @relation("SelectionByUser")
  results            Result[]              @relation("StudentResults")

  // User ↔ Student (1:1)
  studentProfile     Student?

  // Optional: if user directly applies
  applications       InternshipApplication[] @relation("UserApplications")
}

model College {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now())

  departments       Department[]
  students          Student[]
  internshipTargets InternshipTarget[]
  results           Result[]
}

model Department {
  id        String @id @default(uuid())
  name      String
  collegeId String

  college  College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  students Student[]
}

model Student {
  id           String @id @default(uuid())
  userId       String @unique
  collegeId    String
  departmentId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  college    College    @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  applications InternshipApplication[] @relation("StudentApplications")
}

model Ipo {
  id        String   @id @default(uuid())
  name      String
  company   String?
  createdAt DateTime @default(now())

  internships Internship[]
}

model Internship {
  id          String   @id @default(uuid())
  title       String
  description String?
  ipoId       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ipo       Ipo?  @relation(fields: [ipoId], references: [id], onDelete: SetNull)
  createdBy User? @relation("CreatedInternships", fields: [createdById], references: [id], onDelete: SetNull)

  applications InternshipApplication[]
  targets      InternshipTarget[]
}

model InternshipTarget {
  id           String @id @default(uuid())
  internshipId String
  collegeId    String?

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  college    College?   @relation(fields: [collegeId], references: [id], onDelete: SetNull)
}

model InternshipApplication {
  id           String   @id @default(uuid())
  internshipId String
  studentId    String?
  userId       String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  // Student relation
  student Student? @relation("StudentApplications", fields: [studentId], references: [id], onDelete: Cascade)

  // User relation (optional direct)
  user User? @relation("UserApplications", fields: [userId], references: [id], onDelete: SetNull)

  selections Selection[]
  results    Result[]
}

model Selection {
  id            String   @id @default(uuid())
  applicationId String
  selectedById  String?
  createdAt     DateTime @default(now())

  application InternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  selectedBy  User?                 @relation("SelectionByUser", fields: [selectedById], references: [id], onDelete: SetNull)
}

model Result {
  id            String   @id @default(uuid())
  applicationId String
  studentId     String
  collegeId     String?
  resultStatus  String
  createdAt     DateTime @default(now())

  application InternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  student     User                  @relation("StudentResults", fields: [studentId], references: [id], onDelete: Cascade)
  college     College?              @relation(fields: [collegeId], references: [id], onDelete: SetNull)
}
