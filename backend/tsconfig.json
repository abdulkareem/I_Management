{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "src/index.ts",
    "src/app.ts",
    "src/routes/index.ts",
    "src/utils/prisma.ts",
    "src/utils/logger.ts",
    "src/middlewares/errorHandler.ts"
  ]
}
